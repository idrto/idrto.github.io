---
const nav = [
  { href: "/get-started", label: "Get started" },
  { href: "/addressing", label: "Addressing" },
  { href: "/architecture", label: "Architecture" },
  { href: "/case-study/ollama", label: "Case study" },
  { href: "/isv", label: "ISVs" },
  { href: "/pricing", label: "Pricing" },
  { href: "/faq", label: "FAQ" },
];
const path = Astro.url.pathname;
---

<header class="site-header">
  <div class="container site-header__inner">
    <a class="brand" href="/">
      <span class="brand__mark" aria-hidden="true"></span>
      <span class="brand__name">idr.to</span>
    </a>
    <nav class="nav" aria-label="Primary">
      {nav.map((item) => (
        <a class:list={["nav__link", path === item.href && "nav__link--active"]} href={item.href}>
          {item.label}
        </a>
      ))}
      <a class="btn btn--primary nav__cta" href="/evaluate">Start evaluation</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(12px);
    background: rgba(10, 14, 20, 0.85);
    border-bottom: 1px solid var(--border);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.875rem 0;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--text);
    font-weight: 700;
    font-size: 1.125rem;
  }
  .brand:hover { text-decoration: none; }
  .brand__mark {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 12px var(--accent);
  }
  .nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }
  .nav__link {
    padding: 0.4rem 0.65rem;
    font-size: 0.875rem;
    color: var(--text-muted);
    text-decoration: none;
    border-radius: 6px;
  }
  .nav__link:hover,
  .nav__link--active {
    color: var(--text);
    background: var(--bg-elevated);
    text-decoration: none;
  }
  .nav__cta {
    margin-left: 0.5rem;
    padding: 0.45rem 1rem;
    font-size: 0.8125rem;
  }
  @media (max-width: 900px) {
    .site-header__inner { flex-wrap: wrap; }
    .nav { width: 100%; }
  }
</style>
