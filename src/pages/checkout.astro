---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const plan = Astro.url.searchParams.get('plan') ?? 'personal';
const quantity = Math.max(1, Number(Astro.url.searchParams.get('quantity') ?? '1') || 1);

const plans: Record<string, { name: string; unitPrice: number; period: string; desc: string }> = {
  personal: {
    name: 'Personal Bundle',
    unitPrice: 5,
    period: 'year per bundle',
    desc: '1 entity · 1 target · 4 sources · 500 GB/month P2P',
  },
  enterprise: {
    name: 'Enterprise Bundle',
    unitPrice: 50,
    period: 'year per bundle',
    desc: '2 entities · 5 targets · 20 sources · 2 TB/month P2P · advanced ACL',
  },
};

const selected = plans[plan] ?? plans.personal;
const total = (selected.unitPrice * quantity).toFixed(2);
---

<Layout title={`Checkout — ${selected.name} — idr.to`}>
  <Header slot="header" />
  <Footer slot="footer" />

  <section class="section checkout">
    <div class="container checkout__grid">
      <div class="checkout__summary card">
        <p class="eyebrow">Mock checkout</p>
        <h1>Complete purchase</h1>
        <p style="color:var(--text-muted);font-size:0.875rem;">
          Demonstration checkout. Payment is not processed. Bundles stack immediately after provisioning.
        </p>
        <div class="order-line">
          <span>{selected.name} × {quantity}</span>
          <strong>US${total}</strong>
        </div>
        <p class="order-desc">{selected.desc}</p>
        <p class="order-period">Billing: {selected.period}</p>
        <div class="order-total">
          <span>Total due today</span>
          <span>US${total}</span>
        </div>
        <a href="/pricing" class="btn btn--ghost" style="margin-top:1rem;">← Change plan</a>
      </div>

      <form class="card checkout__form" method="dialog">
        <h2 style="margin-top:0;">Bundle quantity</h2>
        <label>
          Quantity
          <input type="number" name="quantity" min="1" max="99" value={quantity} />
        </label>
        <p style="font-size:0.875rem;color:var(--text-muted);">
          All resources from purchased bundles are <strong>pooled</strong> into your account quota.
        </p>
        <button type="submit" class="btn btn--primary" style="margin-top:1rem;">Confirm (mock)</button>
        <p style="font-size:0.8125rem;color:var(--text-muted);margin-top:1rem;">
          After purchase, view quotas on <a href="/account/usage">usage dashboard</a>.
        </p>
      </form>
    </div>
  </section>
</Layout>

<style>
  .checkout__grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr;
    max-width: 56rem;
  }
  @media (min-width: 768px) {
    .checkout__grid { grid-template-columns: 1fr 1fr; }
  }
  .order-line, .order-total {
    display: flex;
    justify-content: space-between;
    margin: 1rem 0;
  }
  .order-total { font-weight: 600; font-size: 1.125rem; border-top: 1px solid var(--border); padding-top: 1rem; }
  .order-desc, .order-period { color: var(--text-muted); font-size: 0.875rem; }
  label { display: block; margin: 1rem 0; }
  input { width: 100%; margin-top: 0.35rem; padding: 0.5rem; }
</style>
