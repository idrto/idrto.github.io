---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const plan = Astro.url.searchParams.get('plan') ?? 'personal';

const plans: Record<string, { name: string; price: string; period: string; desc: string }> = {
  personal: {
    name: 'Personal',
    price: '5.00',
    period: 'year',
    desc: 'Single-level host · up to 5 devices · signaling + P2P',
  },
  enterprise: {
    name: 'Enterprise',
    price: '50.00',
    period: 'year per user',
    desc: 'Multi-level hosts · up to 5 devices · ACLs + priority support',
  },
  'enterprise-monthly': {
    name: 'Enterprise (monthly)',
    price: '5.00',
    period: 'month per user',
    desc: 'Multi-level hosts · billed monthly',
  },
  'data-500': {
    name: 'Data transfer bundle',
    price: '10.00',
    period: '500 GB (rollover 12 mo)',
    desc: 'TURN + HTTPS relay metering',
  },
};

const selected = plans[plan] ?? plans.personal;
---

<Layout title={`Checkout — ${selected.name} — idr.to`}>
  <Header slot="header" />
  <Footer slot="footer" />

  <section class="section checkout">
    <div class="container checkout__grid">
      <div class="checkout__summary card">
        <p class="eyebrow">Mock checkout</p>
        <h1>Complete purchase</h1>
        <p style="color:var(--text-muted);font-size:0.875rem;">
          This is a demonstration Stripe-style page. Payment is not processed.
        </p>
        <div class="order-line">
          <span>{selected.name}</span>
          <strong>US${selected.price}</strong>
        </div>
        <p class="order-desc">{selected.desc}</p>
        <p class="order-period">Billing: {selected.period}</p>
        <div class="order-total">
          <span>Total due today</span>
          <span>US${selected.price}</span>
        </div>
        <a href="/pricing" class="btn btn--ghost" style="margin-top:1rem;">← Change plan</a>
      </div>

      <form class="checkout__form card" id="checkout-form">
        <div class="stripe-badge">
          <svg width="40" height="17" viewBox="0 0 60 25" aria-hidden="true"><path fill="#635bff" d="M59.64 14.28h-8.06c.19 1.93 1.6 2.55 3.2 2.55 1.64 0 2.96-.37 4.05-.95v3.32a8.33 8.33 0 0 1-4.56 1.1c-4.01 0-6.83-2.5-6.83-7.48 0-4.19 2.39-7.52 6.3-7.52 3.92 0 5.96 3.28 5.96 7.5 0 .4-.04 1.26-.06 1.48zm-5.92-5.62c-1.03 0-2.17.73-2.17 2.81h4.25c0-2.05-1.07-2.81-2.08-2.81zM40.95 20.3c-1.44 0-2.32-.6-2.9-1.04l-.02 4.63-4.12.87V5.57h3.76l.08 1.02a4.7 4.7 0 0 1 3.23-1.29c2.9 0 5.62 2.6 5.62 7.4 0 5.23-2.7 7.6-5.65 7.6zM40.2 8.4c-.8 0-1.54.38-1.95 1.02l.02 6.12c.4.63 1.14 1.02 1.95 1.02 1.52 0 2.54-1.65 2.54-4.08 0-2.44-1.02-4.08-2.56-4.08zM28.06 5.57h4.14v14.44h-4.14V5.57zm0-4.7L32.2 0v3.36l-4.14.88V.88zm-4.32 9.35v9.79H19.6V5.57h3.7l.12 1.22c1-1.77 2.87-1.47 3.44-1.22v3.79c-.52-.17-2.29-.43-3.08.86zm-8.08.87c0 2.32 1.03 3.32 2.76 3.32 1.04 0 1.88-.24 2.56-.58v3.64a10.3 10.3 0 0 1-3.56.66c-3.52 0-6.28-2.04-6.28-7.08 0-4.82 2.76-7.08 6.28-7.08a10.3 10.3 0 0 1 3.56.66v3.64c-.68-.34-1.52-.58-2.56-.58-1.73 0-2.76 1-2.76 3.32zM0 5.57h3.77l.12 1.02a4.7 4.7 0 0 1 3.23-1.29c2.9 0 5.62 2.6 5.62 7.4 0 5.23-2.7 7.6-5.65 7.6-1.44 0-2.32-.6-2.9-1.04l-.02 4.63H0V5.57z"/></svg>
          <span>Secure checkout (demo)</span>
        </div>
        <label>
          Email
          <input type="email" required placeholder="you@company.com" />
        </label>
        <label>
          Card number
          <input type="text" required placeholder="4242 4242 4242 4242" maxlength="19" />
        </label>
        <div class="row">
          <label>
            Expiry
            <input type="text" required placeholder="MM / YY" maxlength="7" />
          </label>
          <label>
            CVC
            <input type="text" required placeholder="123" maxlength="4" />
          </label>
        </div>
        <label>
          Name on card
          <input type="text" required placeholder="Jane Smith" />
        </label>
        <button type="submit" class="btn btn--primary pay-btn">Pay US${selected.price}</button>
        <p class="fine-print">Mock page — no charge will be made. After evaluation, production checkout will use Stripe.</p>
      </form>
    </div>

    <div class="container" id="checkout-success" hidden>
      <div class="callout" style="max-width:480px;margin:2rem auto;text-align:center;">
        <h2 style="margin:0 0 0.5rem;">Payment received (demo)</h2>
        <p style="margin:0;color:var(--text-muted);">Thank you. In production you would receive a receipt and entity provisioning email.</p>
        <a class="btn btn--primary" href="/" style="margin-top:1rem;">Back to home</a>
      </div>
    </div>
  </section>
</Layout>

<script>
  document.getElementById('checkout-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    document.querySelector('.checkout__grid')?.setAttribute('hidden', '');
    document.getElementById('checkout-success')?.removeAttribute('hidden');
  });
</script>

<style>
  .checkout__grid {
    display: grid;
    gap: 2rem;
    max-width: 880px;
    margin: 0 auto;
  }
  @media (min-width: 768px) {
    .checkout__grid { grid-template-columns: 1fr 1.1fr; }
  }
  h1 { font-size: 1.75rem; margin: 0 0 0.5rem; }
  .order-line {
    display: flex;
    justify-content: space-between;
    margin-top: 1.5rem;
    font-size: 1.0625rem;
  }
  .order-desc, .order-period {
    color: var(--text-muted);
    font-size: 0.875rem;
    margin: 0.5rem 0 0;
  }
  .order-total {
    display: flex;
    justify-content: space-between;
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    font-weight: 700;
    font-size: 1.125rem;
  }
  .checkout__form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .checkout__form label {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text-muted);
  }
  .checkout__form input {
    padding: 0.75rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg-elevated);
    color: var(--text);
    font-size: 1rem;
  }
  .row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .stripe-badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }
  .pay-btn { width: 100%; margin-top: 0.5rem; padding: 1rem; }
  .fine-print {
    font-size: 0.75rem;
    color: var(--text-muted);
    text-align: center;
    margin: 0;
  }
</style>
