---
interface Props {
  title: string;
  description?: string;
}

import '../styles/global.css';

const { title, description = "idr.to — ID-Based Routing for on-premise edge devices. Secure P2P connectivity with hosted signaling." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="bg" aria-hidden="true">
      <div class="orb orb--one"></div>
      <div class="orb orb--two"></div>
      <div class="grid"></div>
    </div>
    <slot name="header" />
    <main>
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>

<style is:global>
  .bg {
    position: fixed;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    pointer-events: none;
  }
  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.35;
  }
  .orb--one {
    width: 480px;
    height: 480px;
    background: #3dd6c8;
    top: -120px;
    right: -80px;
  }
  .orb--two {
    width: 360px;
    height: 360px;
    background: #4a7cff;
    bottom: 10%;
    left: -100px;
    opacity: 0.2;
  }
  .grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(36, 48, 68, 0.4) 1px, transparent 1px),
      linear-gradient(90deg, rgba(36, 48, 68, 0.4) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse 80% 60% at 50% 0%, black, transparent);
  }
</style>
